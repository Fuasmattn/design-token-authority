{
  "name": "design-token-farm",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./dist/config/index.js"
  },
  "bin": {
    "design-token-farm": "./dist/cli.js",
    "dtf": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prettier:check": "prettier --check src/",
    "dtf": "tsx src/cli.ts",
    "sync-tokens-to-figma": "tsx src/sync_tokens_to_figma.ts",
    "sync-figma-to-tokens": "tsx src/sync_figma_to_tokens.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsx style-dictionary.config.ts",
    "build:cli": "tsc && chmod +x dist/cli.js",
    "prepare": "npm run build:cli"
  },
  "dependencies": {
    "axios": "^1.12.0",
    "commander": "^12.1.0",
    "dotenv": "^16.3.1",
    "style-dictionary": "^4.4.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.19.3",
    "typescript": "^5.1.6"
  },
  "devDependencies": {
    "@figma/rest-api-spec": "^0.10.0",
    "@types/node": "^20.4.5",
    "@vitest/coverage-v8": "^4.1.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0"
  }
}
